{
  "name": "fr33-job-escrow-subgraph",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "set-start-block": "node scripts/set-start-block.mjs",
    "codegen": "graph codegen",
    "build": "graph build",
    "stack:up": "docker compose up -d",
    "stack:down": "docker compose down",
    "stack:logs": "docker compose logs -f graph-node ipfs",
    "create-local": "graph create --node http://127.0.0.1:8020/ fr33/job-escrow",
    "deploy-local": "graph deploy --node http://127.0.0.1:8020 --ipfs http://127.0.0.1:5001 fr33/job-escrow",
    "deploy-local:all": "npm run set-start-block && npm run codegen && npm run build && npm run create-local && npm run deploy-local"
  },
  "devDependencies": {
    "@graphprotocol/graph-cli": "^0.98.1",
    "@graphprotocol/graph-ts": "^0.38.2",
    "typescript": "^5.9.3"
  }
}
