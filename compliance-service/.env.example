# Used by prisma
POSTGRES_URL=postgres://USER:PASS@HOST:PORT/DB?schema=issuer_service

# Private key used to sign VC
VC_SIGNING_PRIVATE_KEY=xxx

# Private key of wallet of issuer - the VC registry
ISSUER_AUTHORISATION_PRIVATE_KEY=xxx

# Address of the deployed VCRegistry contract
VC_REGISTRY_ADDRESS=xxx

# RPC URL for polygon amoy testnet
RPC_URL=xxx

# Compliance monitor toggle
COMPLIANCE_MONITOR_ENABLED=true
COMPLIANCE_MONITOR_VERBOSE=true

# The Graph endpoint exposed by the escrow subgraph
COMPLIANCE_SUBGRAPH_URL=http://localhost:8000/subgraphs/name/fr33/job-escrow

# Polling config
COMPLIANCE_POLL_INTERVAL_MS=5000
COMPLIANCE_FETCH_BATCH_SIZE=200

# Case threshold and rule scores
COMPLIANCE_CASE_THRESHOLD=100
COMPLIANCE_LARGE_ESCROW_SCORE=40
COMPLIANCE_DISPUTE_SCORE=45
COMPLIANCE_BURST_SCORE=30

# Rule thresholds
COMPLIANCE_LARGE_ESCROW_MIN_BASELINE_TX=3
COMPLIANCE_LARGE_ESCROW_LOOKBACK_HOURS=168
COMPLIANCE_LARGE_ESCROW_MULTIPLIER=3
COMPLIANCE_LARGE_ESCROW_ABS_MIN_WEI=50000000000000000
COMPLIANCE_DISPUTE_LOOKBACK_HOURS=168
COMPLIANCE_DISPUTE_MIN_JOBS=3
COMPLIANCE_DISPUTE_RATIO_THRESHOLD=0.4
COMPLIANCE_BURST_WINDOW_MINUTES=30
COMPLIANCE_BURST_MIN_EVENT_COUNT=4