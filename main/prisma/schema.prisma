generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  output          = "../generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("NEXT_POSTGRES_URL")
  schemas  = ["app_service"] // Define the schema name here for multi-schema support
}

enum UserRole {
  WORKER
  EMPLOYER
  ADMIN

  @@schema("app_service")
}

enum OnboardingStage {
  WALLET_PENDING
  KYC_PENDING
  VC_PENDING
  COMPLETED

  @@schema("app_service")
}

// App level account - session ownership
model User {
  id              Int             @id @default(autoincrement())
  email           String          @unique
  passwordHash    String
  role            UserRole        @default(WORKER)
  onboardingStage OnboardingStage @default(WALLET_PENDING)
  createdAt       DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @db.Timestamptz(6)

  wallets          Wallet[] // One to many
  auditLogs        AuditLog[] // One to many
  openedDisputes   Dispute[]         @relation("DisputeOpenedBy")
  decidedDisputes  Dispute[]         @relation("DisputeDecidedBy")
  disputeEvidences DisputeEvidence[]

  @@map("users")
  @@schema("app_service")
}

// Wallets linked to users, with encrypted signer keys for on-chain interactions and KYC/VC metadata
model Wallet {
  id      Int    @id @default(autoincrement())
  userId  Int // Many to one
  address String @unique
  did     String @unique

  encryptedSignerKey String // base64 ciphertext
  signerKeyIv        String // base64 IV

  status           WalletStatus @default(ACTIVE)
  suspensionReason String?
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)

  user       User        @relation(fields: [userId], references: [id])
  vcMetadata VCMetadata?

  @@map("wallets")
  @@schema("app_service")
}

enum WalletStatus {
  ACTIVE
  SUSPENDED
  REVOKED

  @@schema("app_service")
}

// Indicates whether a wallet is KYC verified (or expired), handled with time-bound verification and revocation handling
model VCMetadata {
  id       Int @id @default(autoincrement())
  walletId Int @unique // Many to one

  vcHash String
  txHash String
  status VCStatus @default(VALID) // Revocation status

  issuerDid  String
  subjectDid String

  issuedAt  DateTime  @default(now()) @db.Timestamptz(6)
  expiresAt DateTime  @db.Timestamptz(6)
  revokedAt DateTime? @db.Timestamptz(6)

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@map("vc_metadata")
  @@schema("app_service")
}

enum VCStatus {
  VALID
  EXPIRED
  REVOKED

  @@schema("app_service")
}

// Job metadata to track current state and on-chain tx hashes for each state transition.
model Job {
  id           Int     @id @default(autoincrement()) // Database ID
  employerId   Int
  workerWallet String?
  title        String
  description  String
  amount       Decimal

  fundedTxHash String?
  fundedAt     DateTime?

  acceptTxHash String?
  acceptedAt   DateTime?

  applyReleaseTxHash String?
  applyReleaseAt     DateTime?

  approveReleaseTxHash String?
  approveReleaseAt     DateTime?

  status           JobStatus         @default(POSTED)
  createdAt        DateTime          @default(now()) @db.Timestamptz(6)
  releaseEvidences ReleaseEvidence[]
  disputes         Dispute[]

  @@map("jobs")
  @@schema("app_service")
}

enum JobStatus {
  POSTED
  FUNDED
  IN_PROGRESS
  PENDING_APPROVAL
  COMPLETED
  DISPUTED

  @@schema("app_service")
}

// Audit logs for tracking user actions and system events, with flexible metadata storage for extensibility
model AuditLog {
  id            Int         @id @default(autoincrement())
  userId        Int?
  walletAddress String?
  action        String
  metadata      Json?
  ipAddress     String?
  result        AuditResult
  createdAt     DateTime    @default(now()) @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
  @@schema("app_service")
}

enum AuditResult {
  ALLOWED
  BLOCKED

  @@schema("app_service")
}

// Evidence submitted for a job, which can be used for release approval or dispute resolution. 
model ReleaseEvidence {
  id    Int @id @default(autoincrement())
  jobId Int

  type    EvidenceType // TIMESHEET, DELIVERY, etc
  fileUrl String // S3 path or IPFS hash?
  notes   String?

  uploadedAt DateTime @db.Timestamptz(6)
  uploadedBy Int // userId of worker

  job Job @relation(fields: [jobId], references: [id])

  @@map("release_evidence")
  @@schema("app_service")
}

enum EvidenceType {
  TIMESHEET
  DELIVERY_PROOF
  INVOICE
  OTHER

  @@schema("app_service")
}

enum DisputeStatus {
  OPEN
  EVIDENCE_SUBMISSION
  UNDER_REVIEW
  DECIDED
  ONCHAIN_PENDING
  RESOLVED
  CANCELLED

  @@schema("app_service")
}

enum DisputeOutcome {
  RELEASE_TO_WORKER
  RETURN_TO_EMPLOYER
  SPLIT

  @@schema("app_service")
}

enum DisputeEvidenceType {
  STATEMENT
  DELIVERY_PROOF
  COMMUNICATION_LOG
  SCREENSHOT
  INVOICE
  OTHER

  @@schema("app_service")
}

enum DisputeAuditAction {
  DISPUTE_CREATED
  ESCROW_FREEZE_REQUESTED
  ESCROW_FREEZE_SUCCEEDED
  ESCROW_FREEZE_FAILED
  EVIDENCE_SUBMITTED
  REVIEW_NOTE_ADDED
  DECISION_RECORDED
  ONCHAIN_RESOLUTION_SUBMITTED
  ONCHAIN_RESOLUTION_CONFIRMED
  ONCHAIN_RESOLUTION_FAILED
  TIMEOUT_AUTO_RELEASE_TRIGGERED
  TIMEOUT_AUTO_RELEASE_CONFIRMED
  TIMEOUT_AUTO_RELEASE_FAILED

  @@schema("app_service")
}

model Dispute {
  id             Int           @id @default(autoincrement())
  jobId          Int
  openedByUserId Int
  status         DisputeStatus @default(OPEN)

  freezeTxHash     String?
  resolutionTxHash String?

  decision         DisputeOutcome?
  workerShareBps   Int?
  decisionReason   String?
  adminReviewNote  String?
  decidedByAdminId Int?

  openedAt    DateTime  @default(now()) @db.Timestamptz(6)
  decidedAt   DateTime? @db.Timestamptz(6)
  resolvedAt  DateTime? @db.Timestamptz(6)
  cancelledAt DateTime? @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)

  job       Job               @relation(fields: [jobId], references: [id])
  openedBy  User              @relation("DisputeOpenedBy", fields: [openedByUserId], references: [id])
  decidedBy User?             @relation("DisputeDecidedBy", fields: [decidedByAdminId], references: [id])
  evidences DisputeEvidence[]

  @@index([jobId, status])
  @@map("disputes")
  @@schema("app_service")
}

model DisputeEvidence {
  id                Int                 @id @default(autoincrement())
  disputeId         Int
  submittedByUserId Int
  submittedByRole   UserRole
  evidenceType      DisputeEvidenceType @default(STATEMENT)
  contentText       String
  attachmentUrl     String?
  externalRef       String?
  idempotencyKey    String?
  createdAt         DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @db.Timestamptz(6)

  dispute     Dispute @relation(fields: [disputeId], references: [id])
  submittedBy User    @relation(fields: [submittedByUserId], references: [id])

  @@index([disputeId, createdAt])
  @@map("dispute_evidence")
  @@schema("app_service")
}
