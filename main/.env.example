# Used by next-auth:     openssl rand -base64 32
AUTH_SECRET='xxx'

# Used by prisma
NEXT_POSTGRES_URL=postgres://USER:PASS@HOST:PORT/DB?schema=app_service

# Used by Alchemy for AA
NEXT_ALCHEMY_API_KEY=xxx
NEXT_ALCHEMY_GAS_POLICY_ID=xxx # UUID for the gas policy created in Alchemy

# Generate encrpytion key via `node -e "console.log('WALLET_ENCRYPTION_KEY=' + require('crypto').randomBytes(32).toString('hex'))"`
NEXT_WALLET_ENCRYPTION_KEY=xxx

# Blockchain access
NEXT_ESCROW_CONTRACT_ADDRESS=xxx

# Platform controlled wallet (admin can remove jobs etc.) 
# - use a random wallet in local
# - but in production you use a wallet in metamask
NEXT_ADMIN_PRIVATE_KEY=xxx

# Examples
# - Alchemy: RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# - Local: RPC_URL=http://127.0.0.1:8545
NEXT_RPC_URL=xxx

# Wallet address for VC Registry that deploys VCs as transactions.
NEXT_VC_REGISTRY_ADDRESS=xxx

# Dispute + timeout auto release
NEXT_FUND_RELEASE_TIMEOUT_SECONDS=172800
NEXT_TIMEOUT_RELEASE_WORKER_ENABLED=false
NEXT_TIMEOUT_RELEASE_POLL_MS=60000

# Optional: allow system cron endpoint authentication without session cookies
NEXT_SYSTEM_CRON_KEY=xxx

# Optional: Prisma seed admin credentials (main/prisma/seed.ts)
# - If ADMIN_USERNAME is not an email, seed converts it to: <username>@admin.local
# - Current login form expects email + password
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-in-dev

# Cloudinary (optional, for worker release evidence image upload)
# If omitted, uploads fallback to inline data URLs in DB (dev-only friendly).
CLOUDINARY_CLOUD_NAME=xxx
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx
CLOUDINARY_EVIDENCE_FOLDER=fr33/release-evidence