{
  "name": "fr33",
  "version": "1.0.0",
  "description": "A blueprint for the first trust-minimised, compliance-aware online marketplace for freelance service payments in Singapore.",
  "private": true,
  "workspaces": [
    "smart-contracts",
    "main",
    "compliance-service"
  ],
  "scripts": {
    "build": "npm run build:smart-contracts && npm run build:main && npm run build:compliance",
    "build:smart-contracts": "cd smart-contracts && npm run build",
    "build:main": "cd main && npm i && npm run build",
    "build:compliance": "cd compliance-service && npm i && npm run build",
    "test": "npm run test:smart-contracts && npm run test:main && npm run test:compliance-service",
    "test:smart-contracts": "cd smart-contracts && npm run test",
    "test:main": "cd main && npm run test",
    "test:compliance": "cd compliance-service && npm run test",
    "dev:smart-contracts": "cd smart-contracts && npm run dev",
    "dev:subgraph": "cd smart-contracts/subgraph && npm run deploy-local:all",
    "subgraph:set-start-block": "cd smart-contracts/subgraph && npm run set-start-block",
    "subgraph:stack:up": "cd smart-contracts/subgraph && npm run stack:up",
    "subgraph:stack:down": "cd smart-contracts/subgraph && npm run stack:down",
    "subgraph:stack:logs": "cd smart-contracts/subgraph && npm run stack:logs",
    "subgraph:deploy-local": "cd smart-contracts/subgraph && npm run deploy-local:all",
    "dev:main": "cd main && npm run dev",
    "dev:compliance": "cd compliance-service && npm run dev",
    "lint": "npm run lint:smart-contracts && npm run lint:main && npm run lint:compliance-service",
    "lint:smart-contracts": "cd smart-contracts && npm run lint",
    "lint:main": "cd main && npm run lint",
    "lint:compliance": "cd compliance-service && npm run lint",
    "prisma-setup:main": "cd main && npm run prisma-setup"
  },
  "keywords": [
    "blockchain",
    "web3",
    "smart-contracts",
    "fullstack"
  ],
  "author": "Neo Zhi Xuan",
  "license": "MIT",
  "devDependencies": {
    "hardhat": "^3.0.9"
  }
}
